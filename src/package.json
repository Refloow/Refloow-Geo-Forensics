{
  "name": "refloow-geo-forensics",
  "version": "1.4.0",
  "description": "Application which allows to tag photos to their geologactions using forensics methods of reading metadata and eexif data of photos.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node src/server.js",
    "package": "electron-builder --win --publish never",
    "package:mac": "electron-builder --mac --publish never",
    "package:linux": "electron-builder --linux --publish never"
  },
  "author": "Veljko Vuckovic",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Refloow/Refloow-Geo-Forensics.git"
  },
  "dependencies": {
    "electron-updater": "6.8.3",
    "exiftool-vendored": "35.20.0",
    "express": "5.2.1"
  },
  "devDependencies": {
    "electron": "40.4.0",
    "electron-builder": "26.7.0"
  },
  "build": {
    "appId": "com.refloow.geoforensics",
    "productName": "Refloow Geo Forensics",
    "copyright": "Copyright © Refloow",
    "asar": true,
    "asarUnpack": [
      "node_modules/exiftool-vendored/**",
      "node_modules/exiftool-vendored.exe/**",
      "node_modules/exiftool-vendored.pl/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!npm-debug.log*",
      "!**/.git",
      "!**/.vscode",
      "!**/.idea",
      "!**/*.map",
      "!node_modules/.bin/**/*",
      "!node_modules/electron/**/*",
      "!dist/electron/**/*.js"
    ],
    "win": {
      "icon": "img/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "appx": {
      "identityName": "Refloow.RefloowGeoForensics", 
      "publisher": "CN=8281F212-0778-4AAA-A785-4B72BFF348A9",
      "publisherDisplayName": "Refloow",
      "applicationId": "RefloowGeoForensics",
      "backgroundColor": "#121212"
    },
    "mac": {
      "icon": "img/iconMAC.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "img/Refloow-Geo-Forensics.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Veljko Vuckovic <legal@refloow.com>",
      "description": "Tool for geolocation of evidence."
    },
    "snap": {
      "summary": "Free batch image & video geolocation digital forensics tool. Automatically extract EXIF data, visualize GPS coordinates on maps, and reconstruct event timelines for OSINT",
      "description": "Refloow™ Geo Forensics is a high-performance, open-source digital forensics tool designed for investigators, OSINT practitioners, and security analysts. It automates the extraction of EXIF metadata from batch image sets or videos, visualizes geospatial data on interactive maps, and reconstructs chronological event timelines to uncover hidden connections in digital evidence. Fully private & local, no data collection, no logins required.",
      "confinement": "strict",
      "plugs": [
        "default",
        "removable-media"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Refloow",
      "repo": "Refloow-Geo-Forensics"
    },
    "npmRebuild": false,
    "nsis": {
      "oneClick": false,
      "license": "LICENSE",
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "img/icon.ico",
      "shortcutName": "Refloow Geo Forensics",
      "createDesktopShortcut": true,
      "perMachine": false,
      "uninstallDisplayName": "Refloow Geo Forensics"
    }
  }
}
